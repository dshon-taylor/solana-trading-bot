{
  "name": "solana-momentum-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:wallet": "node scripts/gen_wallet.mjs keys/bot-keypair.json",
    "start": "node src/index.mjs",
    "format": "prettier -w .",
    "lint": "eslint .",
    "typecheck": "node -c src/index.mjs && node -c src/tracker.mjs && node -c src/paper_momentum.mjs && node -c src/replay_optimizer.mjs && node -c src/outcome_labeler.mjs && node -c src/trade_lifecycle_analytics.mjs && node -c scripts/trade_lifecycle_summary.mjs",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test",
    "dryrun:rules": "node scripts/dryrun_rules.mjs",
    "summarize:attempts": "node scripts/paper_live_attempts_summary.mjs",
    "summarize:lifecycle": "node scripts/trade_lifecycle_summary.mjs",
    "pm2:snapshot": "bash scripts/pm2_snapshot_safe.sh solana-momentum-bot",
    "print:config": "node scripts/print_effective_config.mjs",
    "replay:historical": "node scripts/replay_historical.mjs",
    "optimize:replay": "node scripts/optimize_replay.mjs",
    "report:weekly:optimizer": "node scripts/weekly_optimizer_report.mjs",
    "cron:install:weekly:optimizer": "bash scripts/install_weekly_optimizer_report_cron.sh",
    "label:outcomes": "node scripts/label_outcomes.mjs",
    "report:carl:v3": "node scripts/carl_backfill_counterfactual_v3.mjs",
    "autotune:aggressive": "node scripts/aggressive_autotune_controller.mjs --mode dry-run",
    "autotune:aggressive:apply": "node scripts/aggressive_autotune_controller.mjs --mode apply",
    "soak:laserstream:staging": "node scripts/laserstream_staging_soak.mjs"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^16.6.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3"
  },
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  }
}
