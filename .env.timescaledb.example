# TimescaleDB Configuration (for historical data persistence)
# Set TIMESCALE_ENABLED=true to enable time-series data collection
# Requires TimescaleDB or PostgreSQL to be running

TIMESCALE_ENABLED=false
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=trading_bot
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=your_password_here
TIMESCALE_POOL_SIZE=10

# Quick setup with Docker:
# docker run -d --name timescaledb -p 5432:5432 \
#   -e POSTGRES_PASSWORD=your_password_here \
#   -e POSTGRES_DB=trading_bot \
#   timescale/timescaledb:latest-pg16
