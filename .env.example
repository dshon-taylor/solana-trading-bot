# Do NOT commit real secrets.

# =========================
# MOMENTUM RULES (PRIMARY KNOBS)
# =========================
# Entry thresholds (paper engine; live momo uses the SAME thresholds)
# Profile switch: normal|aggressive (aggressive materially increases entry frequency)
MOMENTUM_PROFILE=normal
# Aggressive defaults (used when MOMENTUM_PROFILE=aggressive unless PAPER_ENTRY_* explicitly set)
AGGRESSIVE_PAPER_ENTRY_RET_15M_PCT=0.035
AGGRESSIVE_PAPER_ENTRY_RET_5M_PCT=0.012
AGGRESSIVE_PAPER_ENTRY_GREEN_LAST5=2
AGGRESSIVE_PAPER_ENTRY_COOLDOWN_MS=240000

PAPER_ENTRY_RET_15M_PCT=0.12
PAPER_ENTRY_RET_5M_PCT=0.04
PAPER_ENTRY_GREEN_LAST5=4
PAPER_ENTRY_COOLDOWN_MS=1800000
# Paper mode parity: when true, paper entries are generated by the same scanner/live process
# (with paper-only execution), instead of the legacy standalone paper momentum entry engine.
PAPER_USE_LIVE_PROCESS=true

# Risk rules (single source of truth is LIVE_MOMO_*; paper risk defaults derive from these)
LIVE_MOMO_STOP_AT_ENTRY=true
LIVE_MOMO_STOP_AT_ENTRY_BUFFER_PCT=0.0005
LIVE_MOMO_TRAIL_ACTIVATE_PCT=0.12
LIVE_MOMO_TRAIL_DISTANCE_PCT=0.12

# (Optional explicit paper overrides — usually leave unset)
# PAPER_STOP_AT_ENTRY=true
# PAPER_STOP_AT_ENTRY_BUFFER_PCT=0.0005
# PAPER_TRAIL_ACTIVATE_PCT=0.12
# PAPER_TRAIL_DISTANCE_PCT=0.12

# =========================
# WALLET / SECRETS
# =========================
# Option A (simple but riskier): provide wallet secret key bytes directly in env.
# This mechanism is disabled by default; you MUST explicitly opt in:
# ALLOW_WALLET_SECRET_KEY_ENV=true
# WALLET_SECRET_KEY_JSON=[1,2,3,...]
# or
# WALLET_SECRET_KEY_B64=base64-encoded-secret-bytes

# Option B (recommended): decrypt at runtime using sops (no plaintext on disk)
# SOPS_WALLET_FILE=./secrets/wallet.enc.json

# RPC endpoint (fill later)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Telegram alerts (fill later)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Pass 1 runtime mode switches
# DATA_CAPTURE_ENABLED controls scanner + candidate ledger writes (should stay true for history)
DATA_CAPTURE_ENABLED=true
# EXECUTION_ENABLED controls all real swap execution (scanner + live momo)
# Backward compatibility: if unset, FORCE_TRADING_ENABLED still seeds behavior.
EXECUTION_ENABLED=false
# SIM_TRACKING_ENABLED controls forward-tracking / paper simulation feed
SIM_TRACKING_ENABLED=true
# Tracker ingest observability guardrail (warns if recent sample writes are zero/low)
# TRACK_INGEST_WINDOW_MINUTES=30
# TRACK_INGEST_MIN_POINTS=10
# TRACK_INGEST_EXPECTED_FRACTION=0.20

# Live momo safety switches (legacy/runtime gate)
LIVE_MOMO_ENABLED=false
FORCE_TRADING_ENABLED=false

# Scanner safety
SCANNER_ENTRIES_ENABLED=false
SCANNER_TRACKING_ENABLED=true

# Watchlist trigger mode (decouples ingest from trigger evaluation)
# Rollback switch: WATCHLIST_TRIGGER_MODE=false
# WATCHLIST_TRIGGER_MODE=false
# WATCHLIST_MAX_SIZE=300
# WATCHLIST_EVAL_EVERY_MS=3000
# WATCHLIST_IMMEDIATE_ROUTE_MAX_PER_CYCLE=4
# WATCHLIST_IMMEDIATE_ROUTE_DEDUP_MS=15000
# CONVERSION_CANARY_MODE=false
# CONVERSION_CANARY_COOLDOWN_MS=60000
# CONVERSION_CANARY_TRACE_PATH=./analysis/canary_trace.jsonl
# WATCHLIST_MINT_TTL_MS=2700000
# WATCHLIST_EVICT_MAX_AGE_HOURS=48
# WATCHLIST_EVICT_STALE_CYCLES=24
# ROUTE_CACHE_ENABLED=true
# ROUTE_CACHE_TTL_MS=12000
# ROUTE_CACHE_MAX_SIZE=512
# Aggressive profile defaults (when AGGRESSIVE_MODE=true) if unset:
# WATCHLIST_EVICT_MAX_AGE_HOURS=24
# WATCHLIST_EVICT_STALE_CYCLES=12

# Daily alive ping (optional)
# Example (healthchecks.io): create a check, then set ALIVE_PING_URL to the ping URL.
# ALIVE_PING_URL=
# ALIVE_PING_EVERY_MS=86400000

# Circuit breaker (pause entries after repeated dependency failures)
# CIRCUIT_BREAKER_ENABLED=true
# CIRCUIT_FAILS_DEX=8
# CIRCUIT_FAILS_RPC=5
# CIRCUIT_FAILS_JUP=10
# CIRCUIT_COOLDOWN_MS=1800000

# JSONL retention / rotation (best-effort)
# JSONL_RETENTION_DAYS=30
# JSONL_ROTATE_MAX_BYTES=26214400

# Telegram /diag historical retention (single source: state/diag_events.jsonl)
# Default keeps 90 days so /diag windows can reach ~3 months.
# DIAG_RETENTION_DAYS=90
# Optional legacy override in milliseconds (takes precedence if set):
# DIAG_MAX_WINDOW_MS=7776000000
# Boot replay cap (lines read from diag_events.jsonl):
# DIAG_HYDRATE_MAX_LINES=500000

# Market-data reliability
# PAIR_CACHE_MAX_AGE_MS=420000
# SCAN_BACKOFF_MAX_MS=300000
# JUP_SOURCE_PREFLIGHT_ENABLED=true
# NO_PAIR_RETRY_ATTEMPTS=5
# NO_PAIR_RETRY_ATTEMPTS_CAP=10
# NO_PAIR_RETRY_BASE_MS=300
# NO_PAIR_RETRY_MAX_BACKOFF_MS=4000
# NO_PAIR_RETRY_TOTAL_BUDGET_MS=6000
# Aggressive defaults (if unset): attempts=5 baseMs=90 maxBackoffMs=900 totalBudgetMs=1500
# NO_PAIR_TEMP_TTL_MS=120000
# NO_PAIR_TEMP_TTL_ROUTEABLE_MS=45000
# NO_PAIR_NON_TRADABLE_TTL_MS=1200000
# NO_PAIR_DEAD_MINT_TTL_MS=5400000
# NO_PAIR_REVISIT_MIN_MS=1500
# NO_PAIR_REVISIT_MAX_MS=360000
# NO_PAIR_DEAD_MINT_STRIKES=3
# JUP_ROUTE_FIRST_ENABLED=true
# Alternative routeability provider (DexScreener heuristic fallback when Jupiter is unavailable/no-route)
# ROUTE_ALT_ENABLED=true
# ROUTE_ALT_MIN_LIQ_USD=18000
# ROUTE_ALT_MAX_PRICE_IMPACT_PCT=4.0
# ROUTE_ALT_RAYDIUM_ENABLED=true   # also check Raydium pools in parallel with DexScreener
# SOURCE_MODE=mixed                  # mixed|quality_first
# SOURCE_QUALITY_JUP_SAMPLE_N=8      # only used in quality_first
# SOURCE_QUALITY_REQUIRE_JUP_QUOTEABLE=true
# Early shortlist prefilter (drops obvious low-value candidates BEFORE expensive pair fetch)
# Modes: off|minimal|standard
# - standard: classic stricter shortlist pruning
# - minimal: tiny anti-spam floor only (recommended for aggressive flow)
# - off: explicit disable (no shortlist prefilter drops)
# EARLY_SHORTLIST_PREFILTER_MODE=standard
# EARLY_SHORTLIST_PREFILTER_ENABLED=true
# Aggressive mode can have independent mode override:
# AGGRESSIVE_EARLY_SHORTLIST_PREFILTER_MODE=minimal
# Normal profile defaults (if unset): minLiqUsd=15000 minTx1h=12 minBoostUsd=100
# EARLY_SHORTLIST_PREFILTER_MIN_LIQ_USD=15000
# EARLY_SHORTLIST_PREFILTER_MIN_TX1H=12
# EARLY_SHORTLIST_PREFILTER_MIN_BOOST_USD=100
# Aggressive defaults are heavily relaxed (minimal anti-spam floor): minLiqUsd=1200 minTx1h=1 minBoostUsd=5
# AGGRESSIVE_EARLY_SHORTLIST_PREFILTER_MIN_LIQ_USD=1200
# AGGRESSIVE_EARLY_SHORTLIST_PREFILTER_MIN_TX1H=1
# AGGRESSIVE_EARLY_SHORTLIST_PREFILTER_MIN_BOOST_USD=5
# Optional paid market-data provider (Birdseye Lite)
# BIRDEYE_LITE_ENABLED=false
# BIRDEYE_API_KEY=
# BIRDEYE_LITE_MAX_RPS=12           # safe default under Lite cap (15 RPS)
# BIRDEYE_LITE_CHAIN=solana
# Birdseye Lite CU/request throttle (per mint)
# BIRDEYE_LITE_CACHE_TTL_MS=30000
# BIRDEYE_LITE_PER_MINT_MIN_INTERVAL_MS=15000

# Staging stream provider abstraction (default = existing production behavior)
# STREAMING_PROVIDER_MODE=existing          # existing|laserstream-devnet
# LASERSTREAM_ENABLED=false                 # instant rollback switch when false
# LASERSTREAM_STAGING_MODE=false            # MUST be true to allow laserstream-devnet mode
# LASERSTREAM_DEVNET_WS_URL=wss://devnet.helius-rpc.com/?api-key=...
# LASERSTREAM_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=...
# LASERSTREAM_PROGRAM_IDS=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
# LASERSTREAM_RECONNECT_BASE_MS=1000
# LASERSTREAM_RECONNECT_MAX_MS=15000
# LASERSTREAM_REPLAY_LOOKBACK_SECONDS=120
# LASERSTREAM_HEARTBEAT_STALE_MS=15000
# LASERSTREAM_BUFFER_MAX=2000

# Aggressive entry profile (single-toggle high-throughput mode)
# Rollback: set AGGRESSIVE_MODE=false and restart.
# AGGRESSIVE_MODE=false

# High-conversion live profile (auto-enabled when AGGRESSIVE_MODE=true)
# LIVE_CONVERSION_PROFILE_ENABLED=false
# PAIR_FETCH_CONCURRENCY=2                 # AGGRESSIVE_MODE auto-raises to >=5 (safety-capped at 8)
# LIVE_PARALLEL_QUOTE_FANOUT_N=2
# LIVE_CANDIDATE_SHORTLIST_N=18
# LIVE_REJECT_RECHECK_BURST_ENABLED=true
# LIVE_REJECT_RECHECK_BURST_ATTEMPTS=2
# LIVE_REJECT_RECHECK_BURST_DELAY_MS=140
# LIVE_REJECT_RECHECK_PASSES=1
# LIVE_REJECT_RECHECK_PASS_DELAY_MS=80
# LIVE_TWO_STAGE_SLIPPAGE_RETRY_ENABLED=true
# LIVE_TWO_STAGE_SLIPPAGE_RETRY_BPS=80
# LIVE_TWO_STAGE_SLIPPAGE_MAX_BPS=400
# LIVE_PROBE_CONFIRM_ENABLED=true
# LIVE_PROBE_MAX_CANDIDATES=12
# LIVE_PROBE_MIN_LIQ_USD=8000
# LIVE_PROBE_MIN_TX1H=8
# LIVE_CONFIRM_MIN_LIQ_USD=10000
# LIVE_CONFIRM_MAX_PRICE_IMPACT_PCT=2.5
# Aggressive-only confirm cap (effective cap = max(base, aggressive), hard bounded <=8)
# AGGRESSIVE_CONFIRM_MAX_PRICE_IMPACT_PCT=3.2

# Aggressive force-attempt policy: when AGGRESSIVE_MODE=true and confirm gate passes, attempt immediately (still respects
# execution gate + playbook/circuit; plus bounded anti-thrash protections below).
# Rollback: set FORCE_ATTEMPT_ON_CONFIRM_PASS=false
# FORCE_ATTEMPT_ON_CONFIRM_PASS=true
# FORCE_ATTEMPT_PER_MINT_COOLDOWN_MS=240000
# FORCE_ATTEMPT_MAX_PER_MINT_PER_HOUR=3
# FORCE_ATTEMPT_GLOBAL_MAX_PER_MINUTE=8

# Optional fallback trigger (feature-flagged): allow near-miss momentum entries when routeable+strong liquidity+strong tx
# AGGRESSIVE_MODE automatically defaults fallback to ON unless explicitly set false.
# MOMENTUM_FALLBACK_ENABLED=true
# MOMENTUM_FALLBACK_TOLERANCE=0.85
# MOMENTUM_FALLBACK_MIN_LIQ_USD=15000
# MOMENTUM_FALLBACK_MIN_TX1H=20

# Capital efficiency guardrails
# Keeps a soft SOL reserve when sizing entries: fees + extra reserve + retry buffer.
# MIN_SOL_FOR_FEES=0.06
# CAPITAL_SOFT_RESERVE_SOL=0.01
# CAPITAL_RETRY_BUFFER_PCT=0.10
# Optional throttle; 0 disables.
# MAX_NEW_ENTRIES_PER_HOUR=0

# Autonomous incident playbook
# Auto-shifts to degraded mode (entries paused) when restart/error patterns breach thresholds.
# PLAYBOOK_ENABLED=true
# PLAYBOOK_RESTART_THRESHOLD=3
# PLAYBOOK_RESTART_WINDOW_MS=900000
# PLAYBOOK_ERROR_THRESHOLD=8
# PLAYBOOK_ERROR_WINDOW_MS=600000
# PLAYBOOK_STABLE_RECOVERY_MS=1200000
\nBIRDEYE_WS_URL=wss://birdeye.example/ws\nBIRDEYE_MAX_WS_CONNECTIONS=200\nBIRDEYE_LITE_CACHE_TTL_MS=45000\nBIRDEYE_PER_MINT_MIN_INTERVAL_MS=25000\n
